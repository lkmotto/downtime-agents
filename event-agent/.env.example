# DownTime Event Collection Agent
# Backend API
BACKEND_URL=https://downtime-backend.onrender.com
BACKEND_API_KEY=

# Eventbrite API
EVENTBRITE_TOKEN=

# Data output directory
DATA_DIR=/app/data

# Fetch settings
FETCH_DAYS_AHEAD=14
MAX_EVENTS_PER_CITY=100

# Anti-detection
DELAY_MIN=2.0
DELAY_MAX=8.0

# Sentry error tracking (leave blank to disable)
SENTRY_DSN=
DEPLOY_ENV=prd
